{
  "expo": {
    "name": "EMDR Therapy",
    "slug": "emdr-mobile",
    "version": "1.0.0",
    "description": "EMDR Therapy Assistant — connect therapists and patients for real-time bilateral stimulation sessions.",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "emdr-mobile",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000080"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.emdrtherapy.app",
      "buildNumber": "1",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.emdrtherapy.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "privacyPolicyUrl": "https://64321b1b-5b8c-4c39-af84-06387c04b0cd-00-wzdceite45m2.riker.replit.dev/privacy",
      "supportEmail": "jesuslr@jlrcollaborations.com",
      "supportUrl": "https://64321b1b-5b8c-4c39-af84-06387c04b0cd-00-wzdceite45m2.riker.replit.dev/support"
    }
  }
}
